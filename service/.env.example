# =============================================================================
# Ads Platform — Service 环境配置模板
# =============================================================================
# 复制此文件为 .env 并填入真实值。
# .env 包含密钥等敏感信息，切勿提交到版本控制。
# =============================================================================

# --- 应用 ---
# 调试模式：true=显示详细错误（开发） false=隐藏（生产）
APP_DEBUG=false
# 服务基础 URL（用于 OAuth 回调、重定向等）
APP_URL=http://0.0.0.0:8788
# OAuth 回调白名单（逗号分隔，支持 fnmatch 通配符，留空=允许全部）
OAUTH_ALLOWED_REDIRECTS=http://localhost:*,https://*.example.com
# 跨域白名单（逗号分隔的域名，支持 fnmatch 通配符，留空=仅同源）
CORS_ALLOWED_ORIGINS=http://localhost:5173
# 强制 HSTS（仅在 HTTPS 反向代理环境启用）
FORCE_HSTS=false
# 日志格式：json = JSON 结构化 / line = 单行文本
LOG_FORMAT=json

# --- 数据库（MySQL 8.0） ---
# 所有表使用 erik_ 前缀 + BIGINT snowflake 主键，引擎 InnoDB，字符集 utf8mb4
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ads
DB_USERNAME=root
# 数据库密码（生产环境务必修改）
DB_PASSWORD=
# 持久连接：高并发时复用连接，避免反复握手
DB_PERSISTENT=false
# 连接超时（秒）：设短以快速失败，防止请求堆积
DB_TIMEOUT=3

# --- Redis 7 ---
# 用途：仪表盘缓存、限流计数器、消息队列、告警 Pub/Sub
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Redis 密码（留空=无密码）
REDIS_PASSWORD=

# --- JWT 认证（erikwang2013/jwt-webman） ---
# Token 签名密钥：使用足够长的随机字符串，泄露后需立即更换
JWT_SECRET=
# Token 有效期（秒）：86400 = 24 小时
JWT_TTL=86400

# --- Hashids ID 加解密（erikwang2013/hashids） ---
# 盐值：修改后所有已有 hash 将失效
HASHIDS_SALT=
# 最小 hash 长度（推荐 8，保证安全性）
HASHIDS_MIN_LENGTH=8

# --- 加密（erikwang2013/encryption + encryptable） ---
# 主密钥：32 字符以上，用于 API 层和 DB 字段加密
APP_ENCRYPTION_KEY=
# 加密算法：aes-128-ecb 或 aes-256-cbc
ENCRYPTION_CIPHER=aes-128-ecb
# 历史密钥（密钥轮换时使用，逗号分隔）
ENCRYPTION_PREVIOUS_KEYS=

# --- Elasticsearch（erikwang2013/webman-scout） ---
# 搜索引擎驱动：elasticsearch 或 meilisearch
SCOUT_DRIVER=elasticsearch
# ES 集群地址（多节点逗号分隔）
ES_HOST=127.0.0.1:9200
# 索引名前缀
ES_INDEX=ads_platform

# =============================================================================
# 平台接入凭据（每个广告平台一组）
# =============================================================================
# 不使用的平台留空即可，不会出现在平台列表也不会影响其他功能。
# =============================================================================

# --- 国内平台（16 个） ---

# 巨量引擎（字节跳动 Ocean Engine）- OAuth2 Access-Token 认证
JULIANG_APP_ID=
JULIANG_SECRET=

# 百度营销 - OAuth2 + 信封签名认证
BAIDU_APP_ID=
BAIDU_SECRET=

# 淘宝/阿里妈妈 - OAuth2 + MD5 签名认证
TAOBAO_APP_KEY=
TAOBAO_SECRET=

# 腾讯广告/广点通 - OAuth2 + nonce 防重放认证
TENCENT_APP_ID=
TENCENT_SECRET=

# 快手磁力引擎 - OAuth2 URL 参数认证
KUAISHOU_APP_ID=
KUAISHOU_SECRET=

# 小红书蒲公英/聚光平台 - OAuth2 Bearer 认证
XIAOHONGSHU_APP_KEY=
XIAOHONGSHU_SECRET=

# 微博粉丝通 - OAuth2 Bearer 认证
WEIBO_APP_ID=
WEIBO_SECRET=

# B站花火 - OAuth2 Bearer 认证
BILIBILI_APP_ID=
BILIBILI_SECRET=

# 优酷广告（阿里系，与淘宝共用 MD5 签名算法）
YOUKU_APP_KEY=
YOUKU_SECRET=

# 美团广告（本地生活广告）- OAuth2 Bearer 认证
MEITUAN_APP_ID=
MEITUAN_SECRET=

# 知乎广告（内容营销）- OAuth2 Bearer 认证
ZHIHU_APP_ID=
ZHIHU_SECRET=

# 360推广 - API Key + Sign 自定义头认证
QIHOO360_API_KEY=
QIHOO360_API_SECRET=

# 搜狗推广 - API Key + Sign 自定义头认证
SOGOU_API_KEY=
SOGOU_API_SECRET=

# 友盟 - API Key + MD5 签名认证（仅报表+授权，不支持投放管理）
UMENG_API_KEY=
UMENG_API_SECRET=

# 京东京准通（京东云 MD5 签名认证）
JINGDONG_APP_KEY=
JINGDONG_SECRET=

# 拼多多/多多进宝（PDD 自定义签名认证）
PINDUODUO_CLIENT_ID=
PINDUODUO_CLIENT_SECRET=

# --- 国际平台（13 个） ---

# Google Ads - OAuth2 + GAQL 查询语言，需 developer token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=

# YouTube Ads（Google Ads API，按 VIDEO 广告系列类型筛选）
# 复用上面的 GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET / GOOGLE_DEVELOPER_TOKEN

# Meta Ads（Facebook + Instagram）- Graph API v19
META_APP_ID=
META_APP_SECRET=

# TikTok for Business（国际版，与巨量引擎是不同的 API）
TIKTOK_APP_ID=
TIKTOK_SECRET=

# LinkedIn Ads - Restli 协议，金额为微美元
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Snapchat Ads - 金额为微美元
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Pinterest Ads - 金额为微美元
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Twitter/X Ads
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Amazon Ads - Login with Amazon + Profile 认证
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# The Trade Desk（DSP 程序化购买）- HMAC-SHA256 签名认证
THETRADEDESK_API_KEY=
THETRADEDESK_API_SECRET=

# Spotify Ads（音频广告）
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Twitch Ads - OAuth2 + Client-Id 双认证
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Netflix Ads - OAuth2 client_credentials（机器对机器）
NETFLIX_CLIENT_ID=
NETFLIX_CLIENT_SECRET=
