# =============================================================================
# Ads Platform — Admin 管理后台环境配置模板
# =============================================================================
# admin 是一个独立的 webman-admin v2 实例（端口 8789）。
# 它提供 Vue 3 SPA 的静态文件服务，并处理管理员认证（RBAC + 审计日志）。
# 业务数据（广告计划、报表等）通过 SERVICE_API_URL 指向的 service API 获取。
# =============================================================================

# --- 应用 ---
# 调试模式：true=显示详细错误（开发） false=隐藏（生产）
APP_DEBUG=true

# --- 业务服务 API 地址 ---
# 所有业务查询（计划、报表、账户、平台、告警）均通过 ServiceProxy
# 转发到此地址，不在 admin 内直接操作业务表。
SERVICE_API_URL=http://127.0.0.1:8788/api/v1

# --- 数据库（MySQL 8.0） ---
# 存储 admin 专用表：admin_users / admin_roles / admin_audit_logs。
# 与 service 共享同一个物理 MySQL 实例，通过表名前缀区分（业务 erik_* / 管理 admin_*）。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ads
DB_USERNAME=root
# 数据库密码（生产环境务必修改）
DB_PASSWORD=

# --- Redis 7 ---
# 用途：admin Session 存储、限流计数器、API 响应缓存（可选）
# 使用数据库 1 与 service（数据库 0）隔离 key 空间
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Redis 密码（留空=无密码）
REDIS_PASSWORD=

# --- JWT 认证（erikwang2013/jwt-webman） ---
# 签名密钥：必须与 service 的 JWT_SECRET 不同，以保证安全隔离
JWT_SECRET=admin-jwt-secret-change-me
# Token 有效期（秒）：86400 = 24 小时
JWT_TTL=86400
